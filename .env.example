NODE_ENV=development
PORT=5000
MONGO_URL=mongodb://127.0.0.1:27017/your-db-name
JWT_SECRET=replace-with-a-strong-random-secret
CORS_ORIGIN=http://localhost:3000,https://backend-crm-t4k3.onrender.com

# Used by forgot/reset password flow
FRONTEND_URL=http://localhost:3000

# SMTP credentials for email features
EMAIL_USER=you@example.com
EMAIL_PASS=your-app-password

# Required for admin bootstrap/seed scripts
BOOTSTRAP_ADMIN_EMAIL=owner@yourcompany.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
# Optional
BOOTSTRAP_ADMIN_NAME=Super Admin
BOOTSTRAP_ADMIN_ROLE=superadmin
